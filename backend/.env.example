APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

REALTIME_PROVIDER=gemini
REALTIME_VIDEO_FPS=2
PROCESSOR_FPS=2
ENABLE_FACE_DROOP_PROCESSOR=false

AGENT_NAME=DroopDetection Agent
AGENT_USER_ID=agent
AGENT_INSTRUCTIONS=You are a guidance-only first-aid assistant. Use visible evidence, processor signals, and retrieved guidance to help the wearer assess urgent situations. Never pretend to place calls or take external actions on the user's behalf.

# Vision Agents typically expects provider credentials and Stream credentials in env.
# Fill these in when you wire the realtime backend for real sessions.
STREAM_API_KEY=
STREAM_API_SECRET=
OPENAI_API_KEY=
GEMINI_API_KEY=

